# ============================================================
# .env.example — Barangay Inventory System
# Copy to: inventoryProjBrgy/inventoryProjBrgy/.env.local
# That file is gitignored. NEVER commit real secrets.
# ============================================================

# ─── Database (Option B — MySQL / MariaDB via XAMPP) ────────
# Local default: 127.0.0.1 preferred over "localhost" on Linux
# (localhost may resolve to a Unix socket that XAMPP does not expose).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mimds

# Remote / staging example (fill in real values; NEVER commit them):
# DB_HOST=your-mysql-host.example.com
# DB_PORT=3306
# DB_USER=app_user
# DB_PASS=use_a_strong_password_here
# DB_NAME=mimds

# ─── Application ────────────────────────────────────────────
# APP_ENV: local | staging | production
APP_ENV=local

# APP_URL: base URL for generating permit links in emails
APP_URL=http://localhost/inventoryProjBrgy/inventoryProjBrgy

# ─── JWT (Phase 2 — REST API) ────────────────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# Min 256-bit entropy. Rotate on any suspected compromise.
JWT_SECRET=replace_with_64_hex_chars_minimum
JWT_TTL_SECONDS=3600

# ─── SMTP (Phase 3 — real email notifications) ───────────────
# No SMS in v1. Only SMTP.
# For local testing: use Mailtrap (https://mailtrap.io) or MailHog.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
SMTP_FROM_ADDRESS=noreply@barangay.example.com
SMTP_FROM_NAME=Barangay e-Governance

# Production example (Gmail app password — generate in Google account security):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password_16_chars
# SMTP_FROM_ADDRESS=your@gmail.com
# SMTP_FROM_NAME=Barangay Office

# ─── Mock Payment Provider (Phase 3) ────────────────────────
# Secret used to verify incoming webhook signatures.
# Generate with: php -r "echo bin2hex(random_bytes(24));"
PAYMENT_WEBHOOK_SECRET=replace_with_real_secret

# ─── Outbox Worker ──────────────────────────────────────────
# How many seconds the worker sleeps between poll cycles (local).
# On production, replace with OS cron / Windows Task Scheduler.
WORKER_POLL_INTERVAL_SECONDS=10

# ─── How env_bootstrap.php loads these values ────────────────
# The app reads from: (1) actual environment variables, then
# (2) .env.local if present, then (3) .env.example as last resort.
# env_bootstrap.php already implements this cascade via getenv().
# No library required for local XAMPP development.
