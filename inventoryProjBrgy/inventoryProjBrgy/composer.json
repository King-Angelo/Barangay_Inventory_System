{
	"name": "barangay-inventory/api",
	"description": "REST API (JWT) for Barangay Inventory — Member 4",
	"require": {
		"php": ">=8.0",
		"firebase/php-jwt": "^6.10",
		"phpmailer/phpmailer": "^6.9"
	},
	"require-dev": {
		"phpunit/phpunit": "^10.5"
	},
	"config": {
		"sort-packages": true,
		"audit": {
			"block-insecure": false
		}
	},
	"autoload": {
		"psr-4": {
			"App\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"App\\Tests\\": "tests/"
		}
	}
}
