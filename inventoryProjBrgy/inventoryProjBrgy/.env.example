# ============================================================
# Environment template (no secrets) — Barangay Inventory app root
# Copy to .env.local (recommended) or .env in this same directory.
#   Windows:  copy .env.example .env.local
#   Git Bash: cp .env.example .env.local
# .env.local and .env are gitignored — never commit real passwords or JWT secrets.
# ============================================================
#
# Loading order (env_bootstrap.php + dbcon / api bootstrap):
#   1) Process / server environment variables (highest priority)
#   2) .env.local in this directory
#   3) .env in this directory
# Values from (1) are not overwritten by files.
# .env.example is NOT loaded automatically — it is only a template to copy from.

# ─── Database (Option B — MySQL / MariaDB via XAMPP) ────────
# Local default: 127.0.0.1 preferred over "localhost" on Linux
# (localhost may resolve to a Unix socket that XAMPP does not expose).
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mimds

# Remote / staging example (fill in real values; NEVER commit them):
# DB_HOST=your-mysql-host.example.com
# DB_PORT=3306
# DB_USER=app_user
# DB_PASS=use_a_strong_password_here
# DB_NAME=mimds

# ─── Application ────────────────────────────────────────────
# APP_ENV: local | staging | production
APP_ENV=local

# APP_URL: base URL for generating permit links in emails (adjust to your host)
APP_URL=http://localhost/inventoryProjBrgy/inventoryProjBrgy

# ─── JWT (REST API — api/v1/auth/login) ─────────────────────
# Generate with: php -r "echo bin2hex(random_bytes(32));"
# Min 256-bit entropy. Rotate on any suspected compromise.
JWT_SECRET=replace_with_64_hex_chars_minimum
JWT_ISS=barangay-inventory
# Token lifetime in seconds (60–86400); api uses JWT_TTL
JWT_TTL=3600

# ─── SMTP (outbox worker — worker/send_outbox.php) ──────────
# No SMS in v1. For local testing: Mailpit, Mailtrap, MailHog.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
MAIL_FROM=noreply@barangay.example.com
MAIL_FROM_NAME=Barangay Inventory

# Production example (commented):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_SECURE=tls
# MAIL_FROM=your@gmail.com

# Use SMTP_SECURE=none for local SMTP without TLS (e.g. Mailpit on 1025).

# ─── Mock payment webhooks (optional) ───────────────────────
PAYMENT_WEBHOOK_SECRET=replace_with_real_secret

# ─── Outbox worker (optional local tuning) ──────────────────
WORKER_POLL_INTERVAL_SECONDS=10
