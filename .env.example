# Database — copy to `inventoryProjBrgy/inventoryProjBrgy/.env.local` for local overrides
# (that file is gitignored). You can also set `DB_*` in your shell / Apache env.

# Local (XAMPP / TCP): prefer 127.0.0.1. On Linux PHP, DB_HOST=localhost can use a Unix socket
# that does not exist in some containers → "No such file or directory" from mysqli.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mimds

# Remote / staging example (use your real host; never commit secrets):
# DB_HOST=your-mysql-host.example
# DB_PORT=3306
# DB_USER=app_user
# DB_PASS=use_a_strong_password
# DB_NAME=mimds

# Optional — used later for API / production tuning (safe to omit locally)
# APP_ENV=production
