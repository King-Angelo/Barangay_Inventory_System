# Database — set on Render (Web Service → Environment) or copy this file to:
#   inventoryProjBrgy/inventoryProjBrgy/.env.local
# for local overrides (file is gitignored). XAMPP defaults match when vars are unset.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mimds

# Render Private MySQL: use the internal hostname shown in the dashboard, e.g.
# DB_HOST=mysql-xxxx
# DB_PORT=3306
# DB_USER=your_mysql_user
# DB_PASS=your_secure_password
# DB_NAME=mimds

# Optional — used later for API / production tuning (safe to omit locally)
# APP_ENV=production
