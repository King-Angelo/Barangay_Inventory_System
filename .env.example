# Database — set on Render (Web Service → Environment) or copy this file to:
#   inventoryProjBrgy/inventoryProjBrgy/.env.local
# for local overrides (file is gitignored).

# Local (XAMPP / TCP): prefer 127.0.0.1. On Linux PHP, DB_HOST=localhost can use a Unix socket
# that does not exist in Docker → "No such file or directory" from mysqli.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=mimds

# Render (required for login): set ALL of these on the Web Service. DB_HOST must be the
# internal MySQL private service hostname from the dashboard (e.g. mysql-xxxx), NOT localhost.
# DB_HOST=mysql-xxxx
# DB_PORT=3306
# DB_USER=your_mysql_user
# DB_PASS=your_secure_password
# DB_NAME=mimds

# Optional — used later for API / production tuning (safe to omit locally)
# APP_ENV=production
